[flake8]
max-line-length = 120
exclude =
    backend/datasets,
    backend/models,
    .venv,
    venv,
    __pycache__,
    build,
    dist
# E402: several service modules intentionally set os.environ before importing
#       heavy deps (cv2, deepface) — late imports are deliberate.
# F541: empty f-strings are cosmetic and harmless.
extend-ignore = E302,E303,E501,W503,W504,W605,F401,E711,E722,E741,E402,F541
