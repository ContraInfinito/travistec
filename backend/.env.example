# =============================================================================
# TravisTEC backend configuration
# All variables are OPTIONAL. With no .env at all, the backend runs using the
# local Whisper STT model and the DeepFace emotion detector (no cloud keys).
# Copy to .env and fill in only what you need.
# =============================================================================

# --- Speech-to-Text -----------------------------------------------------------
# Backend to use: local_whisper (default) | local_ctc | azure
STT_SERVICE=local_whisper

# Only required when STT_SERVICE=azure
AZURE_SPEECH_KEY=
AZURE_SERVICE_REGION=

# --- Emotion detection (DeepFace) --------------------------------------------
# Face-detector backend used by DeepFace: opencv (default) | retinaface | mtcnn | ssd
EMOTION_DETECTOR_BACKEND=opencv

# --- Car-price model ----------------------------------------------------------
# The car dataset prices are in lakhs; this multiplier converts to base currency.
CAR_PRICE_UNIT_MULTIPLIER=100000
# Optional: USD per rupee, to also return a USD estimate.
CAR_PRICE_TO_USD_RATE=
